{
  "name": "matchdb-shell-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"webpack serve --config webpack.config.js\" \"tsx server/index.ts\"",
    "dev:https": "concurrently \"webpack serve --config webpack.config.js --env https\" \"cross-env USE_HTTPS=true tsx server/index.ts\"",
    "dev:standalone": "webpack serve --config webpack.config.js",
    "build": "webpack --config webpack.config.js --env production",
    "start": "tsx server/index.ts",
    "start:https": "cross-env USE_HTTPS=true tsx server/index.ts",
    "lint": "eslint src server --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src server --ext .ts,.tsx --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.11",
    "@mui/material": "^5.15.11",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.5",
    "matchdb-component-library": "file:../matchingdb-component-library",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "selfsigned": "^2.4.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/selfsigned": "^2.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "dotenv-webpack": "^8.0.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.0.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
